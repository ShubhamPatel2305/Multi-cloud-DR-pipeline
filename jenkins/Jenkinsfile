// Multi-cloud DR delivery pipeline.
//
// Promotes a single image artifact across three target environments
// (AWS Mumbai, AWS Singapore, Azure) and verifies the post-deployment
// health of each before continuing. A simulated regional outage and a
// canary failback drill run on the demo stack at the end as a smoke
// test of the DR posture itself.

@Library('dr-shared') _

pipeline {
    agent any

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 45, unit: 'MINUTES')
    }

    parameters {
        booleanParam(
            name: 'RUN_DR_DRILL',
            defaultValue: true,
            description: 'Run failover + canary failback drill against the demo stack after deploy'
        )
        choice(
            name: 'DEPLOY_TARGETS',
            choices: ['all', 'primary-only', 'standby-only', 'dr-only'],
            description: 'Restrict deployment scope. Use during incident response.'
        )
    }

    environment {
        IMAGE_NAME    = 'shubhampatel2305/dr-demo-api'
        IMAGE_TAG     = "${env.GIT_COMMIT?.take(8) ?: env.BUILD_NUMBER}"
        FULL_IMAGE    = "${IMAGE_NAME}:${IMAGE_TAG}"

        AWS_PRIMARY_REGION   = 'ap-south-1'
        AWS_STANDBY_REGION   = 'ap-southeast-1'
        AZURE_RG             = 'rg-dr-secondary'

        ROUTER_URL  = 'http://router.dr-demo.internal:8000'
        SLACK_CHAN  = '#deploys'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    currentBuild.description = "image=${FULL_IMAGE}"
                }
            }
        }

        stage('Lint & Unit Tests') {
            parallel {
                stage('app') {
                    steps {
                        sh '''
                            cd app
                            python -m pip install --user -q -r requirements.txt
                            python -m pip install --user -q ruff pytest pytest-asyncio
                            python -m ruff check src tests
                            PYTHONPATH=. python -m pytest -q
                        '''
                    }
                }
                stage('router') {
                    steps {
                        sh '''
                            cd router
                            python -m pip install --user -q -r requirements.txt
                            python -m pip install --user -q ruff pytest pytest-asyncio
                            python -m ruff check src tests
                            PYTHONPATH=. python -m pytest -q
                        '''
                    }
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'dockerhub-creds') {
                        def img = docker.build("${FULL_IMAGE}", '--pull -f app/Dockerfile app')
                        img.push()
                        img.push('latest')
                    }
                }
            }
        }

        stage('Security Scan') {
            steps {
                sh """
                    docker run --rm -v /var/run/docker.sock:/var/run/docker.sock \
                        aquasec/trivy:latest image --exit-code 1 --severity CRITICAL ${FULL_IMAGE} || \
                        (echo 'Trivy found CRITICAL vulnerabilities'; exit 1)
                """
            }
        }

        stage('Deploy: AWS Primary (Mumbai)') {
            when {
                expression { params.DEPLOY_TARGETS in ['all', 'primary-only'] }
            }
            steps {
                deployEcs(
                    region: env.AWS_PRIMARY_REGION,
                    cluster: 'dr-primary-cluster',
                    service: 'dr-primary-svc',
                    image: env.FULL_IMAGE
                )
                verifyHealthy(albVar: 'PRIMARY_ALB', minHealthyTargets: 2)
            }
        }

        stage('Deploy: AWS Standby (Singapore)') {
            when {
                expression { params.DEPLOY_TARGETS in ['all', 'standby-only'] }
            }
            steps {
                deployEcs(
                    region: env.AWS_STANDBY_REGION,
                    cluster: 'dr-standby-cluster',
                    service: 'dr-standby-svc',
                    image: env.FULL_IMAGE
                )
                verifyHealthy(albVar: 'STANDBY_ALB', minHealthyTargets: 1)
            }
        }

        stage('Deploy: Azure DR') {
            when {
                expression { params.DEPLOY_TARGETS in ['all', 'dr-only'] }
            }
            steps {
                deployContainerApp(
                    rg: env.AZURE_RG,
                    app: 'ca-dr-api',
                    image: env.FULL_IMAGE
                )
                verifyHealthy(albVar: 'AZURE_FQDN', minHealthyTargets: 1)
            }
        }

        stage('Smoke Tests') {
            steps {
                sh '''
                    set -euo pipefail
                    for region in PRIMARY STANDBY AZURE; do
                        url_var="${region}_ALB"
                        url=$(eval echo \\$$url_var)
                        echo "→ Smoke testing $region at $url"
                        curl -fsS "$url/health/live"
                        curl -fsS "$url/health/ready"
                    done
                '''
            }
        }

        stage('DR Drill') {
            when {
                expression { params.RUN_DR_DRILL }
            }
            steps {
                drDrill(routerUrl: env.ROUTER_URL, target: 'aws-mumbai')
            }
        }
    }

    post {
        success {
            slackSend(
                channel: env.SLACK_CHAN,
                color: 'good',
                message: ":rocket: deploy ${env.JOB_NAME} #${env.BUILD_NUMBER} (${env.SHORT_SHA}) green. ${currentBuild.description}"
            )
        }
        failure {
            slackSend(
                channel: env.SLACK_CHAN,
                color: 'danger',
                message: ":fire: deploy ${env.JOB_NAME} #${env.BUILD_NUMBER} failed at stage `${env.STAGE_NAME}`. ${env.BUILD_URL}"
            )
        }
        always {
            archiveArtifacts artifacts: 'app/**/htmlcov/**, **/junit.xml', allowEmptyArchive: true
            cleanWs()
        }
    }
}
