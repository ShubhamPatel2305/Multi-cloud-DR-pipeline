# --- App ---
APP_NAME=dr-demo-api
APP_ENV=local
APP_PORT=8080
REGION_ID=aws-mumbai
REGION_PRIORITY=1
LOG_LEVEL=info

# --- Database ---
# Use a real Atlas connection string in cloud, or the docker-compose mongo for local
MONGO_URI=mongodb://mongo:27017/dr_demo
MONGO_TIMEOUT_MS=2000

# --- Failure injection (for chaos / runbook drills) ---
INJECT_FAILURE=false
FAILURE_MODE=none

# --- Mock router ---
ROUTER_PORT=8000
POLL_INTERVAL_SECONDS=3
UNHEALTHY_THRESHOLD=2
HEALTHY_THRESHOLD=2
DEEP_PROBE_INTERVAL_SECONDS=15

# Origin pool — read by the router on startup
ORIGIN_PRIMARY_URL=http://aws-mumbai:8080
ORIGIN_STANDBY_URL=http://aws-singapore:8080
ORIGIN_DR_URL=http://azure-secondary:8080
